{
  "permissions": {
    "allow": [
      "Bash(npm init:*)",
      "Bash(npm install:*)",
      "Bash(dir:*)",
      "Bash(npm uninstall:*)",
      "Bash(cmd /c \"dir C:\\\\Works\\\\claude\\\\ai-trpg /b 2>&1\")",
      "Bash(cmd /c \"dir C:\\\\Works\\\\claude\\\\ai-trpg /A 2>&1\")",
      "Bash(cmd /c \"dir C:\\\\Works\\\\claude\\\\ai-trpg\")",
      "Bash(Get-ChildItem:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(rm:*)",
      "Bash(ls:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(npx tsc *)",
      "Bash(npx vitest *)"
    ],
    "deny": [
      "Bash(cmd /c \"dir C:\\\\Works\\\\claude\\\\ai-trpg\\\\\\.env\")",
      "Bash(cmd /c \"dir C:\\\\Works\\\\claude\\\\ai-trpg\\\\node_modules\")"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H \"Content-Type: application/json\" -H \"X-Emdash-Token: $EMDASH_HOOK_TOKEN\" -H \"X-Emdash-Pty-Id: $EMDASH_PTY_ID\" -H \"X-Emdash-Event-Type: notification\" -d @- \"http://127.0.0.1:$EMDASH_HOOK_PORT/hook\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H \"Content-Type: application/json\" -H \"X-Emdash-Token: $EMDASH_HOOK_TOKEN\" -H \"X-Emdash-Pty-Id: $EMDASH_PTY_ID\" -H \"X-Emdash-Event-Type: stop\" -d @- \"http://127.0.0.1:$EMDASH_HOOK_PORT/hook\" || true"
          }
        ]
      }
    ]
  }
}
